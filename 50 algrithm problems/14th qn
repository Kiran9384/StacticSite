function mergeArrays(arr1, arr2) {
    let merged = [];

    // copy first array
    for (let i = 0; i < arr1.length; i++) {
        merged[merged.length] = arr1[i];
    }

    // copy second array
    for (let j = 0; j < arr2.length; j++) {
        merged[merged.length] = arr2[j];
    }

    return merged;
}

let a = [1, 2, 3];
let b = [14, 15, 16];

console.log(mergeArrays(a, b));